rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/{familyCode}/contacts/{contactId} {
      // Allow read/write access if the familyCode matches format and the contact data is valid
      allow read, write: if isValidFamilyCode(familyCode)
                          && (request.method == 'DELETE' || isValidContact(request.resource.data));
    }
    
    function isValidFamilyCode(code) {
      return code.size() >= 8 && code.size() <= 40 && code.matches('^[a-z0-9_\\-]+$');
    }
    
    function isValidContact(data) {
      return data.id is string
          && data.name is string
          && data.name.size() <= 30
          && data.phoneNumber is string
          && data.phoneNumber.matches('^\\+?[0-9]{7,15}$')
          && (data.whatsappNumber == null || (data.whatsappNumber is string && data.whatsappNumber.matches('^\\+?[0-9]{7,15}$')))
          && data.colorTheme is string
          && data.colorTheme.matches('^#[0-9A-Fa-f]{6}$')
          && data.preferredAction in ['call', 'video', 'message']
          && data.positionIndex is int
          // Enforce 350KB limit on photo and voice base64 payloads to protect against Firestore 1MB limits
          && (data.photoUrl == null || (data.photoUrl is string && data.photoUrl.size() < 358400))
          && (data.voiceLabelUrl == null || (data.voiceLabelUrl is string && data.voiceLabelUrl.size() < 358400));
    }
  }
}
