rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /families/{familyCode}/contacts/{contactId} {
      // Allow read/write access if the familyCode matches format and the contact data is valid
      allow read: if isValidFamilyCode(familyCode);
      allow delete: if isValidFamilyCode(familyCode);
      allow create, update: if isValidFamilyCode(familyCode) && isValidContact(request.resource.data);
    }

    match /families/{familyCode}/commands/{commandId} {
      allow read: if isValidFamilyCode(familyCode);
      allow write: if isValidFamilyCode(familyCode) && isValidCommand(request.resource.data);
    }

    match /families/{familyCode}/telemetry/{telemetryId} {
      allow read: if isValidFamilyCode(familyCode);
      allow write: if isValidFamilyCode(familyCode) && isValidTelemetry(request.resource.data);
    }

    match /families/{familyCode}/alarms/{alarmId} {
      allow read: if isValidFamilyCode(familyCode);
      allow delete: if isValidFamilyCode(familyCode);
      allow create, update: if isValidFamilyCode(familyCode) && isValidAlarm(request.resource.data);
    }
    
    function isValidFamilyCode(code) {
      return code.size() >= 8 && code.size() <= 40 && code.matches('^[a-z0-9_\\-]+$');
    }
    
    function isValidContact(data) {
      return data.id is string
          && data.name is string
          && data.name.size() <= 30
          && data.phoneNumber is string
          && data.phoneNumber.matches('^\\+?[0-9 \\-\\(\\)]{7,25}$')
          && (data.get('whatsappNumber', null) == null || (data.get('whatsappNumber', null) is string && data.get('whatsappNumber', null).matches('^\\+?[0-9 \\-\\(\\)]{7,25}$')))
          && data.colorTheme is string
          && data.colorTheme.matches('^#[0-9A-Fa-f]{6}$')
          && data.preferredAction in ['call', 'video', 'message']
          && data.positionIndex is int
          // Enforce 350KB limit on photo and voice base64 payloads to protect against Firestore 1MB limits
          && (data.get('photoUrl', null) == null || (data.get('photoUrl', null) is string && data.get('photoUrl', null).size() < 358400))
          && (data.get('voiceLabelUrl', null) == null || (data.get('voiceLabelUrl', null) is string && data.get('voiceLabelUrl', null).size() < 358400));
    }

    function isValidCommand(data) {
      return data.trigger is bool
          && (data.get('timestamp', null) == null || data.timestamp is timestamp || data.timestamp is string);
    }

    function isValidTelemetry(data) {
      return data.batteryLevel is int
          && data.batteryLevel >= 0 && data.batteryLevel <= 100
          && data.isCharging is bool
          && data.signalStrength in ['good', 'weak', 'disconnected']
          && data.simState in ['ready', 'absent', 'locked', 'error', 'unknown']
          && data.gpsLocation is string
          && (data.get('lastUpdated', null) == null || data.lastUpdated is timestamp || data.lastUpdated is string);
    }

    function isValidAlarm(data) {
      return data.id is string
          && data.time is string
          && data.time.matches('^[0-9]{2}:[0-9]{2}$')
          && data.label is string
          && data.days is list
          && data.isEnabled is bool
          && (data.get('lastUpdated', null) == null || data.lastUpdated is timestamp || data.lastUpdated is string);
    }
  }
}
